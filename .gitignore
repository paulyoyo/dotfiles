# Bare dotfiles repo .gitignore
# Default: ignore everything in $HOME, explicitly un-ignore tracked files.
# This prevents `config status` from showing thousands of untracked files.

*

# Un-ignore the files/dirs we actually track
!.gitignore
!README.md
!.zshrc
!.zprofile
!.zshenv
!.secrets.example

# Kitty config
!.config/
.config/*
!.config/kitty/
!.config/kitty/kitty.conf
!.config/kitty/Salvaje.conf
!.config/kitty/salvaje-banner.sh
!.config/kitty/salvaje-banner.txt
!.config/kitty/salvaje-shell.sh
!.config/starship.toml
!.config/starship-terminal.toml
!.config/terminal-profiles/
!.config/terminal-profiles/Salvaje.terminal
# zellij — stock defaults, no custom config tracked

# Neovim / LazyVim config
!.config/nvim/
.config/nvim/*
!.config/nvim/init.lua
!.config/nvim/stylua.toml
!.config/nvim/lazy-lock.json
!.config/nvim/lua/
!.config/nvim/lua/**
!.config/nvim/colors/
!.config/nvim/colors/**

# pwnvim is NOT tracked here — it's an upstream distro managed via git
# pull inside ~/.config/pwnvim. Only the Neovide wrapper + config that
# route the GUI to it live in this repo.
# .config/pwnvim/ intentionally absent from un-ignores.

# Neovide GUI config
!.config/neovide/
!.config/neovide/config.toml

# nvim-pwnvim launcher (.local/bin wrapper)
!.local/
.local/*
!.local/bin/
.local/bin/*
!.local/bin/nvim-pwnvim

# Never commit secrets
.secrets
