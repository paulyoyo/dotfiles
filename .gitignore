# Bare dotfiles repo .gitignore
# Default: ignore everything in $HOME, explicitly un-ignore tracked files.
# This prevents `config status` from showing thousands of untracked files.

*

# Un-ignore the files/dirs we actually track
!.gitignore
!.zshrc
!.zprofile
!.zshenv
!.secrets.example

# Kitty config
!.config/
.config/*
!.config/kitty/
!.config/kitty/kitty.conf
!.config/kitty/Salvaje.conf
!.config/starship.toml
!.config/starship-terminal.toml
!.config/terminal-profiles/
!.config/terminal-profiles/Salvaje.terminal
!.config/zellij/
!.config/zellij/config.kdl
!.config/zellij/themes/
!.config/zellij/themes/salvaje.kdl
!.config/zellij/layouts/
!.config/zellij/layouts/default.kdl

# NOT tracked:
#   .config/zellij/plugins/*.wasm   (binary, self-updates from GitHub)
#   .config/zellij/plugins/*.sh     (auto-generated hook script)
#   .config/zellij/plugins/*.json   (per-machine plugin state)

# Never commit secrets
.secrets
