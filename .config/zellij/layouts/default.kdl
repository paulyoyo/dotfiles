// ~/.config/zellij/layouts/default.kdl
// Overrides the zellij built-in default layout so that zellaude replaces
// the top tab bar in every new session.
//
// zellaude: https://github.com/ishefi/zellaude
//   Claude Code activity bar for zellij — shows per-session status,
//   permission requests, elapsed time. Self-installs a Claude Code hook
//   at ~/.config/zellij/plugins/zellaude-hook.sh on first load.
//
// Bottom status bar is kept from the stock default layout.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zellaude.wasm"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
}
