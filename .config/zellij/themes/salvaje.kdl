// ~/.config/zellij/themes/salvaje.kdl
// Salvaje — warm dark theme built from 5 anchor colors.
//
// Anchors:
//   Deep Lilac    #8956BA  (primary accent)
//   Bright Snow   #F7F7F5  (foreground)
//   Golden Glow   #EAD82F  (warm accent)
//   Black         #060100  (canvas)
//   Wisteria      #C599E2  (lighter lilac, magenta slot)
//
// Derived via split-complement / triadic from Deep Lilac:
//   Rose          #E0637A  (red)
//   Sage          #8FBF6C  (green)
//   Teal          #6AAFB8  (cyan)
//   Lilac-grey    #2A1A38  (dim accent)
//   Bright Lilac  #A474D4  (bright blue)

themes {
    salvaje {
        fg      "#F7F7F5"
        bg      "#060100"
        black   "#120E15"
        red     "#E0637A"
        green   "#8FBF6C"
        yellow  "#EAD82F"
        blue    "#8956BA"
        magenta "#C599E2"
        cyan    "#6AAFB8"
        white   "#F7F7F5"
        orange  "#C599E2"
    }
}
