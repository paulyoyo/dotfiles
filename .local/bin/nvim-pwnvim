#!/bin/bash
# ~/.local/bin/nvim-pwnvim
#
# Launches neovim using the pwnvim config (~/.config/pwnvim).
# Neovide's config.toml points neovim-bin at this wrapper (via a symlink
# at /opt/homebrew/bin/nvim-pwnvim, because Neovide unquotes the path
# through a shell and $HOME contains spaces on this machine).
#
# Terminal `nvim` is unaffected — it continues to use LazyVim at
# ~/.config/nvim.
#
# The `-c "set guifont=..."` argument is evaluated AFTER pwnvim's
# init.lua, so it overrides anything pwnvim might set and doesn't
# depend on Neovide's [font] section in config.toml working (which is
# inconsistent across Neovide versions).

export NVIM_APPNAME=pwnvim

# pwnvim's catppuccin config uses `background = { light = "latte",
# dark = "mocha" }`, i.e. it picks the flavor from vim.o.background
# at colorscheme load time. Neovim defaults to `background=dark` which
# gives mocha — but the pwnvim README screenshot is latte (cream, warm).
# Setting background via `--cmd` runs BEFORE init.lua, so catppuccin
# sees `light` when it loads and picks latte instead.
#
# Neovide guifont format: comma-separated font list, size (:hN) appears
# ONCE at the end. Spaces in font family names escaped with backslash.
exec /opt/homebrew/bin/nvim \
  --cmd 'set background=light' \
  -c 'set guifont=GT\ Pressura\ LCGV\ Mono,MesloLGS\ Nerd\ Font\ Mono:h18' \
  "$@"
